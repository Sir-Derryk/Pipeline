{
    "project_name": "BimNv C++ API Reference",
    "src_dir": [
        "../../../sdk_sources/BimNv/Include"
    ],
    "static_pages_dir": "./",
    "copyright_start_year": 2002,
    "incremental": true,
    "max_workers": 8,
    "collector": {
        "type": "CppDoxygenCollector",
        "file_patterns": [
            "**/*.h"
        ],
        "include_private": false
    },
    "parser": {
        "type": "CppDoxygenParser"
    },
    "renderer": {
        "type": "CppHtmlDefaultRenderer"
    },
    "output_subdir": "bimnv_api_cpp",
    "validator": {
        "type": "CppCommentValidator"
    }
}