{
    "project_name": "FacetModeler C++ API Reference",
    "src_dir": [
        "../../../main/FacetModeler/include"
    ],
    "static_pages_dir": "Dev_Guides/FacetModeler",
    "copyright_start_year": 2002,
    "incremental": true,
    "max_workers": 8,
    "collector": {
        "type": "CppDoxygenCollector",
        "file_patterns": [
            "**/*.h"
        ],
        "include_private": false
    },
    "parser": {
        "type": "CppDoxygenParser"
    },
    "renderer": {
        "type": "CppHtmlDefaultRenderer"
    },
    "output_subdir": "facetmodeler_api_cpp",
    "validator": {
        "type": "CppCommentValidator"
    }
}