{
    "project_name": "Mock C++ API Reference",
    "src_dir": [
        "../../../engine/tests/assets/main/mock"
    ],
    "static_pages_dir": "./",
    "copyright_start_year": 2026,
    "incremental": true,
    "max_workers": 8,
    "collector": {
        "type": "cpp",
        "file_patterns": [
            "**/*.h"
        ],
        "include_private": false
    },
    "parser": {
        "type": "doxygen_xml"
    },
    "renderer": {
        "type": "html"
    },
    "output_subdir": "mock_api_cpp"
}
